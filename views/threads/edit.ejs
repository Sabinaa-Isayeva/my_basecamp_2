<%- include("../partials/header", { pageTitle }) %>

<div class="card shadow-sm border-0 rounded-4">
  <div class="card-body p-4">
    <h1 class="h3 mb-3">Edit Thread</h1>
    <p class="text-secondary">
      Project: <strong><%= project.title %></strong>
    </p>

    <form action="/projects/<%= project.id %>/threads/<%= thread.id %>?_method=PUT" method="POST">
      <div class="mb-3">
        <label class="form-label" for="title">Thread title</label>
        <input
          class="form-control"
          id="title"
          name="title"
          value="<%= thread.title %>"
          required
        />
      </div>

      <div class="d-flex gap-2">
        <button class="btn btn-primary" type="submit">Save Thread</button>
        <a href="/projects/<%= project.id %>/threads/<%= thread.id %>" class="btn btn-outline-secondary">
          Cancel
        </a>
      </div>
    </form>
  </div>
</div>

<%- include("../partials/footer") %>
