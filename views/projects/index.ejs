<%- include("../partials/header", { pageTitle }) %>

<div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-4">
  <div>
    <h1 class="h2 mb-1">Projects</h1>
    <p class="text-secondary mb-0">
      <% if (currentUser.isAdmin) { %>
        You can see every project because you are an admin.
      <% } else { %>
        These are your personal projects.
      <% } %>
    </p>
  </div>
  <a href="/projects/new" class="btn btn-primary">New Project</a>
</div>

<% if (projects.length === 0) { %>
  <div class="card shadow-sm border-0 rounded-4">
    <div class="card-body p-4 text-center">
      <h2 class="h4">No projects yet</h2>
      <p class="text-secondary">Create your first project to get started.</p>
      <a href="/projects/new" class="btn btn-primary">Create Project</a>
    </div>
  </div>
<% } else { %>
  <div class="row g-4">
    <% projects.forEach(function(project) { %>
      <div class="col-md-6 col-xl-4">
        <div class="card h-100 shadow-sm border-0 rounded-4">
          <div class="card-body">
            <div class="d-flex justify-content-between align-items-start gap-2">
              <h2 class="h5"><%= project.title %></h2>
              <span class="badge text-bg-light border"><%= project.owner.name %></span>
            </div>
            <p class="text-secondary">
              <%= project.description || "No description added." %>
            </p>
          </div>
          <div class="card-footer bg-white border-0 pt-0 pb-3 px-3">
            <div class="d-flex gap-2 flex-wrap">
              <a href="/projects/<%= project.id %>" class="btn btn-sm btn-outline-primary">
                Open
              </a>
              <a href="/projects/<%= project.id %>/edit" class="btn btn-sm btn-outline-secondary">
                Edit
              </a>
              <form action="/projects/<%= project.id %>?_method=DELETE" method="POST">
                <button class="btn btn-sm btn-outline-danger" type="submit">Delete</button>
              </form>
            </div>
          </div>
        </div>
      </div>
    <% }) %>
  </div>
<% } %>

<%- include("../partials/footer") %>
