<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= pageTitle || "My Basecamp 1" %></title>
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/css/styles.css" />
  </head>
  <body class="bg-light">
    <nav class="navbar navbar-expand-lg navbar-dark bg-primary shadow-sm">
      <div class="container">
        <a class="navbar-brand fw-bold" href="/">My Basecamp</a>
        <button
          class="navbar-toggler"
          type="button"
          data-bs-toggle="collapse"
          data-bs-target="#navbarNav"
        >
          <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="navbarNav">
          <div class="navbar-nav me-auto">
            <a class="nav-link" href="/">Home</a>
            <% if (currentUser) { %>
              <a class="nav-link" href="/projects">Projects</a>
              <a class="nav-link" href="/users/<%= currentUser.id %>">Profile</a>
              <% if (currentUser.isAdmin) { %>
                <a class="nav-link" href="/users">Users</a>
              <% } %>
            <% } %>
          </div>

          <div class="d-flex align-items-center gap-2">
            <% if (currentUser) { %>
              <span class="text-white small">
                <strong><%= currentUser.name %></strong>
                <% if (currentUser.isAdmin) { %>
                  (Admin)
                <% } %>
              </span>
              <form action="/sign-out?_method=DELETE" method="POST" class="m-0">
                <button class="btn btn-light btn-sm" type="submit">Sign Out</button>
              </form>
            <% } else { %>
              <a class="btn btn-outline-light btn-sm" href="/users/new">Register</a>
              <a class="btn btn-light btn-sm" href="/sign-in">Sign In</a>
            <% } %>
          </div>
        </div>
      </div>
    </nav>

    <main class="container py-4">
      <% if (flash) { %>
        <div class="alert alert-<%= flash.type %> alert-dismissible fade show" role="alert">
          <%= flash.message %>
          <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
      <% } %>
