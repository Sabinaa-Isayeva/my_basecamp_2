<%- include("../partials/header", { pageTitle }) %>

<div class="card shadow-sm border-0 rounded-4">
  <div class="card-body p-4">
    <h1 class="h3 mb-3">Edit Message</h1>

    <p class="text-secondary">
      Thread:
      <a href="/projects/<%= project.id %>/threads/<%= thread.id %>">
        <%= thread.title %>
      </a>
    </p>

    <form
      action="/projects/<%= project.id %>/threads/<%= thread.id %>/messages/<%= message.id %>?_method=PUT"
      method="POST"
    >
      <div class="mb-3">
        <label class="form-label" for="body">Message</label>
        <textarea
          class="form-control"
          id="body"
          name="body"
          rows="5"
          required
        ><%= message.body %></textarea>
      </div>

      <div class="d-flex gap-2">
        <button class="btn btn-primary" type="submit">Save Message</button>
        <a
          href="/projects/<%= project.id %>/threads/<%= thread.id %>"
          class="btn btn-outline-secondary"
        >
          Cancel
        </a>
      </div>
    </form>
  </div>
</div>

<%- include("../partials/footer") %>
