<%- include("../partials/header", { pageTitle }) %>

<div class="row g-4">
  <div class="col-lg-4">
    <div class="card shadow-sm border-0 rounded-4">
      <div class="card-body p-4">
        <h1 class="h3 mb-1"><%= profileUser.name %></h1>
        <p class="text-secondary mb-3"><%= profileUser.email %></p>

        <p class="mb-2">
          <strong>Role:</strong>
          <%= profileUser.isAdmin ? "Admin" : "User" %>
        </p>
        <p class="mb-4">
          <strong>Total projects:</strong>
          <%= profileUser.projects.length %>
        </p>

        <div class="d-grid gap-2">
          <a href="/projects" class="btn btn-primary">View Projects</a>

          <% if (currentUser.isAdmin && profileUser.id !== currentUser.id) { %>
            <% if (profileUser.isAdmin) { %>
              <form action="/users/<%= profileUser.id %>/admin?_method=DELETE" method="POST">
                <button class="btn btn-outline-warning w-100" type="submit">Remove Admin</button>
              </form>
            <% } else { %>
              <form action="/users/<%= profileUser.id %>/admin" method="POST">
                <button class="btn btn-outline-success w-100" type="submit">Make Admin</button>
              </form>
            <% } %>
          <% } %>

          <% if (currentUser.isAdmin || currentUser.id === profileUser.id) { %>
            <form action="/users/<%= profileUser.id %>?_method=DELETE" method="POST">
              <button class="btn btn-outline-danger w-100" type="submit">Delete User</button>
            </form>
          <% } %>
        </div>
      </div>
    </div>
  </div>

  <div class="col-lg-8">
    <div class="card shadow-sm border-0 rounded-4">
      <div class="card-body p-4">
        <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3">
          <h2 class="h4 mb-0">Projects</h2>
          <% if (currentUser.id === profileUser.id) { %>
            <a href="/projects/new" class="btn btn-sm btn-outline-primary">New Project</a>
          <% } %>
        </div>

        <% if (profileUser.projects.length === 0) { %>
          <p class="text-secondary mb-0">No projects yet.</p>
        <% } else { %>
          <div class="list-group">
            <% profileUser.projects.forEach(function(project) { %>
              <a
                href="/projects/<%= project.id %>"
                class="list-group-item list-group-item-action"
              >
                <strong><%= project.title %></strong>
              </a>
            <% }) %>
          </div>
        <% } %>
      </div>
    </div>
  </div>
</div>

<%- include("../partials/footer") %>
