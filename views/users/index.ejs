<%- include("../partials/header", { pageTitle }) %>

<div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-4">
  <div>
    <h1 class="h2 mb-1">Users</h1>
    <p class="text-secondary mb-0">Manage accounts and admin permissions.</p>
  </div>
  <a href="/projects" class="btn btn-outline-primary">Back to Projects</a>
</div>

<div class="card shadow-sm border-0 rounded-4">
  <div class="table-responsive">
    <table class="table align-middle mb-0">
      <thead class="table-light">
        <tr>
          <th>Name</th>
          <th>Email</th>
          <th>Role</th>
          <th>Projects</th>
          <th class="text-end">Actions</th>
        </tr>
      </thead>
      <tbody>
        <% users.forEach(function(user) { %>
          <tr>
            <td>
              <a href="/users/<%= user.id %>" class="fw-semibold text-decoration-none">
                <%= user.name %>
              </a>
            </td>
            <td><%= user.email %></td>
            <td>
              <% if (user.isAdmin) { %>
                <span class="badge text-bg-primary">Admin</span>
              <% } else { %>
                <span class="badge text-bg-secondary">User</span>
              <% } %>
            </td>
            <td><%= user.projects.length %></td>
            <td class="text-end">
              <div class="d-flex justify-content-end flex-wrap gap-2">
                <% if (user.isAdmin) { %>
                  <form action="/users/<%= user.id %>/admin?_method=DELETE" method="POST">
                    <button class="btn btn-sm btn-outline-warning" type="submit">
                      Remove Admin
                    </button>
                  </form>
                <% } else { %>
                  <form action="/users/<%= user.id %>/admin" method="POST">
                    <button class="btn btn-sm btn-outline-success" type="submit">
                      Make Admin
                    </button>
                  </form>
                <% } %>

                <form action="/users/<%= user.id %>?_method=DELETE" method="POST">
                  <button class="btn btn-sm btn-outline-danger" type="submit">
                    Delete
                  </button>
                </form>
              </div>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>

<%- include("../partials/footer") %>
